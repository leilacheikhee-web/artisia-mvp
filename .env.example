# ── Artisia AI — Environment Variables ──────────────────────────────────────

# Set to "true" to run in demo mode (no API key needed)
USE_MOCK=false

# Choose your LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (if using OpenAI instead)
OPENAI_API_KEY=sk-...
